# Supabase — https://supabase.com/dashboard
EXPO_PUBLIC_SUPABASE_URL=https://mqzzsjfjugblwliotpjw.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optionnel — forcer l'URL OAuth si l'IP Expo change souvent :
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=exp://192.168.x.x:8081/--/auth/callback

# Back-office (demandes organisateur) — URL accessible depuis le téléphone / émulateur
# Exemple LAN : http://192.168.1.10:3000
EXPO_PUBLIC_BACKOFFICE_URL=http://localhost:3000

# Supabase → Authentication → URL Configuration
# Site URL (Expo Go) : exp://VOTRE_IP:8081  (PAS localhost, PAS supabase.co)
# Redirect URLs (une par ligne) :
#   exp://VOTRE_IP:8081/--/auth/callback
#   exp://VOTRE_IP:8081
#   exp://**
#   invyra://auth/callback
