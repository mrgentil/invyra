{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@components/*": [
        "components/*"
      ],
      "@ui/*": [
        "components/ui/*"
      ],
      "@cards/*": [
        "components/cards/*"
      ],
      "@buttons/*": [
        "components/buttons/*"
      ],
      "@forms/*": [
        "components/forms/*"
      ],
      "@maps/*": [
        "components/maps/*"
      ],
      "@modals/*": [
        "components/modals/*"
      ],
      "@hooks/*": [
        "hooks/*"
      ],
      "@services/*": [
        "services/*"
      ],
      "@api/*": [
        "api/*"
      ],
      "@store/*": [
        "store/*"
      ],
      "@types/*": [
        "types/*"
      ],
      "@constants/*": [
        "constants/*"
      ],
      "@theme/*": [
        "theme/*"
      ],
      "@utils/*": [
        "utils/*"
      ]
    },
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
